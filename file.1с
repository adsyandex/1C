// Процедура для обработки таблицы товаров
Процедура ОбработатьТаблицуТоваров(ТаблицаТоваров)
    
    Счетчик = 0;
    
    Для Каждого СтрокаТаблицы Из ТаблицаТоваров Цикл
        
        // Проверяем условие, например, если количество больше 10
        Если СтрокаТаблицы.Количество > 10 Тогда
            
            // Формируем текст сообщения
            ТекстСообщения = "Товар " + СтрокаТаблицы.Номенклатура + " превышает лимит!";
            
            // Выводим сообщение пользователю
            Сообщить(ТекстСообщения);
            
            Счетчик = Счетчик + 1;
            
        КонецЕсли;
        
    КонецЦикла;
    
    Сообщить("Всего обработано позиций с превышением: " + Счетчик);
    
КонецПроцедуры

